# AthletiX — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs

# === Garmin Connect ===
GARMIN_EMAIL=votre.email@example.com
GARMIN_PASSWORD=votre_mot_de_passe

# === Base de données ===
# Chemin absolu ou relatif depuis le dossier backend/
DATABASE_PATH=./athletix.db

# === Serveur API ===
API_HOST=127.0.0.1
API_PORT=8000
