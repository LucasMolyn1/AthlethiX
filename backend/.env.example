# AthletiX — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Credentials Strava (créer une app sur https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=ton_client_id
STRAVA_CLIENT_SECRET=ton_client_secret
# URL de callback — doit correspondre à celle configurée dans l'app Strava
STRAVA_REDIRECT_URI=https://athletix.xn--lm-systmes-56a.fr/api/strava/callback

# Base de données SQLite
DATABASE_PATH=/opt/athletix/backend/athletix.db

# Serveur FastAPI
API_HOST=127.0.0.1
API_PORT=8000
